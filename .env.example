# ROCWAY 配置环境变量示例（自动被 viper 通过 SetEnvPrefix("ROCWAY") + AutomaticEnv 识别）

# HTTP
ROCWAY_SERVER_ADDR=:8080
ROCWAY_SERVER_MODE=debug

# MySQL
ROCWAY_DATABASE_WRITE_HOST=127.0.0.1
ROCWAY_DATABASE_WRITE_PORT=3306
ROCWAY_DATABASE_WRITE_USER=root
ROCWAY_DATABASE_WRITE_PASSWORD=root
ROCWAY_DATABASE_WRITE_DBNAME=rocway

# Redis
ROCWAY_CACHE_ADDR=127.0.0.1:6379
ROCWAY_CACHE_PREFIX=rocway:

# JWT
ROCWAY_AUTH_JWT_SECRET=change-me
ROCWAY_AUTH_ACCESS_TTL_SEC=3600
ROCWAY_AUTH_REFRESH_TTL_SEC=604800

# Storage
ROCWAY_STORAGE_DRIVER=local
ROCWAY_STORAGE_LOCAL_DIR=storage
ROCWAY_STORAGE_PUBLIC_BASE=/storage

# Logger
ROCWAY_LOGGER_LEVEL=info
ROCWAY_LOGGER_DIR=logs
ROCWAY_LOGGER_MAX_MB=100
ROCWAY_LOGGER_BACKUP=7
