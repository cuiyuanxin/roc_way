#!/bin/bash
# pre-commit hook for roc_way
# 确保代码格式、静态分析、测试全部通过后再提交

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit hooks...${NC}"

# 检查 Go 代码格式
echo -e "${YELLOW}Checking Go code formatting...${NC}"
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}ERROR: The following files are not formatted:${NC}"
    echo "$UNFORMATTED"
    echo -e "${RED}Run 'gofmt -w .' to format them.${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Go formatting check passed${NC}"

# 运行静态分析
echo -e "${YELLOW}Running go vet...${NC}"
if ! go vet ./... 2>&1; then
    echo -e "${RED}ERROR: go vet found issues${NC}"
    exit 1
fi
echo -e "${GREEN}✓ go vet passed${NC}"

# 运行单元测试（不包含集成测试）
echo -e "${YELLOW}Running go test...${NC}"
if ! go test ./... -short 2>&1; then
    echo -e "${RED}ERROR: Some tests failed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ All tests passed${NC}"

echo -e "${GREEN}Pre-commit checks passed!${NC}"
exit 0
