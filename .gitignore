# 编辑器
.idea/
.vscode/
.trae
*.swp

# skills
/skills-lcak.json
/.agents
/agent

# 构建产物
/bin/
/dist/
/storage/
/logs/
/*.exe
/internal/wire/wire_gen.go

# air 热启动临时产物
/tmp/
/air_errors.log
/tmp/*.exe

# Windows 上误生成的 nul 保留设备名占位文件
/nul

# Go
*.test
*.out
coverage.*

# 不提交 vendor（依据 project_rules.md）
/vendor/

# 环境变量
.env
.env.local

# 本地开发用 HTTPS 证书（mkcert 生成，不入库；configs/certs/.gitkeep 保留目录）
/configs/certs/server.crt
/configs/certs/server.key

# Phase 2 改为 Phase 2.5: HS256 智能 secret 管理
# - dev 模式自动生成的 secret（不留空 secret 字段时）
# - 用户自己生成的本地开发用 secret
# 生产**必须**走 env JWT_SECRET（不写文件，K8s Secret / Vault 注入）
/configs/.jwt_secret
/configs/.jwt_secret.bak
